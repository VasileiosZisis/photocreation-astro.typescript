---
import BaseLayout from "../layouts/BaseLayout.astro";
import { pageMetadata } from "../data/pages";
import { cloudinaryImage } from "../utils/cloudinary";
import "../styles/contact-page.css";
---

<BaseLayout {...pageMetadata["/contact/"]}>
  <div class="contact-page">
    <section class="contact-page__hero" aria-labelledby="contact-title" data-motion="text-left">
      <p class="contact-page__eyebrow">Contact Studio Photo Creation</p>
      <h1 id="contact-title" class="contact-page__title">Start with the date, place, and story</h1>
      <p class="contact-page__summary">
        Reach Dimitris directly for wedding, christening, proposal, family, and
        portrait photography in Paphos and across Cyprus
      </p>
    </section>

    <section class="contact-page__intro" aria-label="Contact details">
      <div class="contact-page__image-wrap">
        <img
          class="contact-page__image"
          src={cloudinaryImage("https://res.cloudinary.com/dmdbza74n/image/upload/v1632243600/studiophotocreation/wedding-stories/jemma-carl/CARL_JEMMA_13_j0orvq.webp", 1000)}
          alt="Wedding couple photographed by Studio Photo Creation."
          data-motion="image"
        />
      </div>
      <div class="contact-page__details" data-motion="text-right" style="--motion-delay: 140ms">
        <h2 class="contact-page__details-title">Find Us</h2>
        <ul class="contact-page__links">
          <li class="contact-page__link-item">
            <span class="contact-page__icon" aria-hidden="true">f</span>
            <div>
              <span class="contact-page__label">Facebook</span>
              <a href="https://www.facebook.com/DomouchtsisDimitris" target="_blank" rel="noreferrer">
                DomouchtsisDimitris
              </a>
            </div>
          </li>
          <li class="contact-page__link-item">
            <span class="contact-page__icon" aria-hidden="true">ig</span>
            <div>
              <span class="contact-page__label">Instagram</span>
              <a href="https://www.instagram.com/studiophotocreation/" target="_blank" rel="noreferrer">
                @studiophotocreation
              </a>
            </div>
          </li>
          <li class="contact-page__link-item">
            <span class="contact-page__icon" aria-hidden="true">@</span>
            <div>
              <span class="contact-page__label">Email</span>
              <a href="mailto:photocreation@cytanet.com.cy">photocreation@cytanet.com.cy</a>
            </div>
          </li>
          <li class="contact-page__link-item">
            <span class="contact-page__icon" aria-hidden="true">tel</span>
            <div>
              <span class="contact-page__label">Phone</span>
              <a href="tel:+35799541649" title="+357 99 54 1649">+357 99 54 1649</a>
            </div>
          </li>
        </ul>
      </div>
    </section>

    <section class="contact-page__location" aria-label="Studio location">
      <div class="contact-page__address" data-motion="text-left">
        <p class="contact-page__eyebrow">Studio address</p>
        <div class="contact-page__address-line">
          <p>Apostolou Pavlou 14A Paphos CY 8046</p>
        </div>
        <img
          class="contact-page__studio-image"
          src={cloudinaryImage("https://res.cloudinary.com/dmdbza74n/image/upload/v1632245788/studiophotocreation/Location_1_ordr1u.webp", 900)}
          alt="Front view of the Studio Photo Creation photography studio in Paphos."
          data-motion="image"
          style="--motion-delay: 120ms"
        />
      </div>
      <div class="contact-page__map" data-motion="text-right" style="--motion-delay: 180ms">
        <iframe
          title="Studio Photo Creation location on Google Maps"
          src="https://www.google.com/maps?q=Apostolou%20Pavlou%2014A%2C%20Paphos%208046%2C%20Cyprus&output=embed"
          loading="lazy"
          allowfullscreen
          referrerpolicy="no-referrer-when-downgrade"
        ></iframe>
      </div>
    </section>
  </div>
</BaseLayout>
