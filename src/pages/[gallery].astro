---
import { getCollection } from "astro:content";

import GalleryGrid from "../components/GalleryGrid.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import "../styles/gallery-page.css";

export const getStaticPaths = async () => {
  const galleries = await getCollection("galleries");

  return galleries.map((gallery) => ({
    params: { gallery: gallery.data.slug },
    props: { gallery },
  }));
};

const { gallery } = Astro.props;
const { title, description, seo, images, slug } = gallery.data;
---

<BaseLayout {...seo}>
  <section class="gallery-page">
    <header class="gallery-page__header">
      <h1 class="gallery-page__title">{title}</h1>
      <p class="gallery-page__description">{description}</p>
    </header>
    <GalleryGrid images={images} galleryId={`${slug}-gallery`} />
  </section>
  <script>
    import "../scripts/photoswipe-gallery";
  </script>
</BaseLayout>
